                    $avatar = ($doctor->user && $doctor->user->avatar)
                        ? asset('storage/avatars/' . $doctor->user->avatar)
                        : asset('images/default-avatar.png');
                    $doctorName = $doctor->name ?: ($doctor->user->full_name ?? 'Doctor');
                @endphp
                <div class="doctor-item">
                    <img src="{{ $avatar }}" alt="{{ $doctorName }}">
                    <h3>{{ $doctorName }}</h3>
                    <p>{{ $doctor->specialty->name ?? 'Specialty' }}</p>
                    <p>Rating: {{ round($doctor->reviews_avg_rating, 1) ?? 'N/A' }}</p>
